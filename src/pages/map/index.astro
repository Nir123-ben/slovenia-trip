---
import Base from '../../layouts/Base.astro';
import { days } from '../../data/trip.ts';
import { toSlug } from '../../utils/slugs.ts';
import { attractionGeo, lodgingGeo } from '../../data/geo.ts';

const attractions = days
  .flatMap(d => d.attractions.map((a, i) => ({
    name: a.name,
    day: d.num,
    type: 'attraction',
    coord: attractionGeo[toSlug(a.name, i)],
  })))
  .filter(p => p.coord);

const seen = new Set<string>();
const lodgings: { name: string; day: number; type: string; coord: [number, number] }[] = [];
for (const d of days) {
  const n = d.accommodation.name;
  if (lodgingGeo[n] && !seen.has(n)) {
    seen.add(n);
    lodgings.push({ name: n, day: d.num, type: 'lodging', coord: lodgingGeo[n] });
  }
}
const allPoints = [...attractions, ...lodgings];
const route = lodgings.map(l => l.coord);
