---
// src/pages/days/[day]/[attraction].astro
import { days } from '../../../data/trip.ts';
import { attractionContent } from '../../../data/rich-content.ts';
import { toSlug } from '../../../utils/slugs.ts';

export function getStaticPaths() {
  return days.flatMap(day =>
    day.attractions.map((attr, i) => ({
      params: {
        day: String(day.num),
        attraction: toSlug(attr.name, i),
      },
      props: { day, attr, attrIndex: i },
    }))
  );
}

const { day, attr, attrIndex } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const slug = toSlug(attr.name, attrIndex);
const content = attractionContent[slug];
const rg = content?.routeGuide;

const alertStyles: Record<string, string> = {
  ok:   'background:rgba(93,232,160,0.08);border-right:3px solid #5de8a0;color:rgba(93,232,160,0.9)',
  warn: 'background:rgba(255,210,80,0.08);border-right:3px solid #ffd250;color:rgba(255,210,80,0.9)',
  cold: 'background:rgba(100,160,255,0.08);border-right:3px solid #7ab4ff;color:rgba(150,190,255,0.9)',
  info: 'background:rgba(100,180,255,0.08);border-right:3px solid #60b0ff;color:rgba(180,220,255,0.9)',
};
---

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{attr.name} — יום {day.num}</title>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;700;900&display=swap" rel="stylesheet">
  {rg && <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css" />}
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    :root {
      --bg: #0d1a14;
      --surface: #16241b;
      --green: #5de8a0;
      --gold: #ffd250;
      --text: #e8ece9;
      --muted: rgba(255,255,255,0.45);
      --border: rgba(255,255,255,0.08);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Heebo', sans-serif;
      background: var(--bg);
      color: var(--text);
      direction: rtl;
      max-width: 520px;
      margin: 0 auto;
      min-height: 100vh;
    }

    /* HERO */
    .hero {
      position: relative;
      height: 100svh;
      min-height: 480px;
      max-height: 640px;
      overflow: hidden;
      background: #060e09;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 30% 60%, #1a3d28 0%, #060e09 70%);
    }
    .hero-img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center 40%;
      opacity: 0.72;
    }
    .hero-atm {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(5,15,10,.97) 0%, rgba(5,15,10,.25) 50%, transparent 100%);
    }
    .hero-top {
      position: absolute;
      top: 0; left: 0; right: 0;
      padding: 18px 20px 40px;
      background: linear-gradient(to bottom, rgba(0,0,0,.55), transparent);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .back {
      color: rgba(255,255,255,.8);
      text-decoration: none;
      font-size: 13px;
      font-weight: 700;
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.2);
      padding: 6px 14px;
      border-radius: 99px;
      backdrop-filter: blur(6px);
    }
    .hero-date { font-size: 11px; color: rgba(255,255,255,.5); letter-spacing: .1em; text-transform: uppercase; }
    .hero-body {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 0 22px 30px;
    }
    .hero-tag {
      display: inline-block;
      font-size: 10px; font-weight: 700;
      letter-spacing: .15em; text-transform: uppercase;
      color: var(--green);
      border: 1px solid rgba(93,232,160,.4);
      padding: 3px 11px; border-radius: 3px;
      margin-bottom: 10px;
    }
    .hero-title {
      font-size: clamp(30px, 9vw, 44px);
      font-weight: 900;
      color: #fff;
      line-height: 1.0;
      letter-spacing: -0.03em;
      margin-bottom: 8px;
    }
    .hero-desc {
      font-size: 14px;
      color: rgba(255,255,255,.65);
      font-weight: 300;
      line-height: 1.6;
      margin-bottom: 14px;
    }
    .hero-chips { display: flex; flex-wrap: wrap; gap: 7px; }
    .chip {
      font-size: 11px; font-weight: 600;
      padding: 4px 11px; border-radius: 3px;
      letter-spacing: .04em;
    }
    .chip-green { background:rgba(93,232,160,.15); border:1px solid rgba(93,232,160,.35); color:var(--green); }
    .chip-gold  { background:rgba(255,210,80,.15);  border:1px solid rgba(255,210,80,.35);  color:var(--gold); }

    /* NAV */
    .sec-nav {
      position: sticky; top: 0; z-index: 50;
      background: rgba(13,26,20,.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      display: flex; overflow-x: auto;
      padding: 0 10px; scrollbar-width: none;
    }
    .sec-nav::-webkit-scrollbar { display: none; }
    .sn {
      font-size: 12px; font-weight: 700;
      color: var(--muted);
      text-decoration: none;
      padding: 13px 12px;
      white-space: nowrap;
      border-bottom: 2px solid transparent;
      letter-spacing: .04em;
    }
    .sn.active, .sn:hover { color: var(--green); border-bottom-color: var(--green); }

    /* BODY */
    .body { padding: 0 18px 64px; }
    .sec { padding: 28px 0; border-bottom: 1px solid var(--border); }
    .sec:last-child { border-bottom: none; }
    .sec-head { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .sec-num { font-size: 10px; font-weight: 700; letter-spacing:.14em; text-transform:uppercase; color: var(--green); }
    .sec-title { font-size: 19px; font-weight: 900; letter-spacing:-.02em; }

    /* LEAD */
    .lead { font-size: 15px; line-height: 1.8; color: rgba(255,255,255,.72); margin-bottom: 16px; }
    .lead strong { color: var(--green); }

    /* IMG BLEED */
    .img-bleed { margin: 16px -18px; overflow: hidden; }
    .img-bleed img { width:100%; height:220px; object-fit:cover; display:block; filter:brightness(.85) saturate(1.1); }
    .img-caption { padding:6px 18px; font-size:11px; color:var(--muted); font-style:italic; text-align:center; }

    /* ALERT */
    .alert-box { border-radius:4px; padding:11px 14px; font-size:13px; line-height:1.7; margin-bottom:9px; }
    .alert-box strong { font-weight:700; }

    /* FACTS GRID */
    .facts-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .fact {
      background: rgba(255,255,255,.04);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 13px;
    }
    .fact-icon { font-size:22px; margin-bottom:5px; display:block; }
    .fact-lbl { font-size:10px; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); margin-bottom:2px; }
    .fact-val { font-size:13px; font-weight:700; line-height:1.3; }

    /* FLOW */
    .flow { display:flex; flex-direction:column; }
    .flow-row { display:grid; grid-template-columns:14px 1fr; gap:0 12px; }
    .flow-mid { display:flex; flex-direction:column; align-items:center; }
    .flow-dot {
      width:8px; height:8px; border-radius:50%;
      background:rgba(255,255,255,.15);
      border:2px solid rgba(255,255,255,.2);
      flex-shrink:0; margin-top:3px;
    }
    .flow-row.hl .flow-dot {
      background: var(--green); border-color: var(--green);
      width:10px; height:10px; margin-top:2px;
      box-shadow: 0 0 8px rgba(93,232,160,.5);
    }
    .flow-line { flex:1; width:1px; background:var(--border); margin:4px auto 0; min-height:18px; }
    .flow-row.hl .flow-line { background:rgba(93,232,160,.25); }
    .flow-content { padding-bottom:18px; }
    .flow-title { font-size:14px; font-weight:600; line-height:1.4; }
    .flow-row.hl .flow-title { font-weight:800; font-size:15px; color:#fff; }
    .flow-note { font-size:12px; color:var(--muted); line-height:1.6; margin-top:3px; }

    /* BRING */
    .bring-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .bring-item {
      background:rgba(255,255,255,.04);
      border:1px solid var(--border);
      border-radius:8px;
      padding:10px 12px;
      font-size:13px;
      display:flex; align-items:center; gap:8px;
      color:rgba(255,255,255,.8);
    }
    .bring-item.no {
      border-color:rgba(255,80,80,.2);
      color:rgba(255,120,120,.7);
      text-decoration:line-through; opacity:.7;
    }
    .bi { font-size:18px; flex-shrink:0; }
    .bring-hint { font-size:12px; color:var(--muted); margin-bottom:10px; }
    .bring-item[data-key] { cursor:pointer; -webkit-tap-highlight-color:transparent; }
    .bring-item.done { border-color:rgba(93,232,160,.45); background:rgba(93,232,160,.08); }
    .bring-item.done .bi-label { text-decoration:line-through; opacity:.6; }
    .bring-item.done::after { content:'✓'; margin-right:auto; color:var(--green); font-weight:800; font-size:15px; }

    /* BTNS */
    .btn-row { display:flex; gap:8px; flex-wrap:wrap; }
    .btn {
      flex:1; display:inline-flex; align-items:center; justify-content:center; gap:5px;
      font-family:'Heebo',sans-serif; font-size:12px; font-weight:700;
      padding:9px 14px; border-radius:5px;
      text-decoration:none; border:none; cursor:pointer; letter-spacing:.03em;
    }
    .btn-primary { background:var(--green); color:#051a0d; }
    .btn-ghost { background:rgba(255,255,255,.06); color:rgba(255,255,255,.8); border:1px solid var(--border); }
    .btn-waze { background:#1a1aff; color:white; }
  </style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  {content?.heroImage
    ? <img class="hero-img" src={content.heroImage} alt={attr.name} loading="eager" />
    : attr.images?.[0] && <img class="hero-img" src={attr.images[0]} alt={attr.name} loading="eager" />
  }
  <div class="hero-atm"></div>
  <div class="hero-top">
    <a class="back" href={`${base}/days/${day.num}/`}>← יום {day.num}</a>
    <span class="hero-date">יום {day.num} · אטרקציה</span>
  </div>
  <div class="hero-body">
    <div class="hero-tag">🌍 אטרקציה {attrIndex + 1} מתוך {day.attractions.length}</div>
    <h1 class="hero-title">{attr.name}</h1>
    <p class="hero-desc">{attr.desc.slice(0, 100)}...</p>
    {content && (
      <div class="hero-chips">
        {content.facts.slice(0, 3).map(f => (
          <span class={f.label === 'צילום' && f.val.includes('אסור') ? 'chip chip-gold' : 'chip chip-green'}>
            {f.icon} {f.val}
          </span>
        ))}
      </div>
    )}
  </div>
</div>

<!-- NAV -->
<nav class="sec-nav">
  {content ? (
    <>
      <a class="sn active" href="#why">למה ללכת</a>
      <a class="sn" href="#know">לדעת לפני</a>
      <a class="sn" href="#experience">החוויה</a>
      <a class="sn" href="#bring">מה לקחת</a>
      {content.routeGuide && <a class="sn" href="#route">מסלול</a>}
      <a class="sn" href="#practical">מעשי</a>
    </>
  ) : (
    <>
      <a class="sn active" href="#info">מידע</a>
      <a class="sn" href="#practical">מעשי</a>
    </>
  )}
</nav>

<div class="body">

  {content ? (
    <>
      <!-- 01 · למה ללכת -->
      <section class="sec" id="why">
        <div class="sec-head"><span class="sec-num">01</span><span class="sec-title">למה ללכת</span></div>
        <p class="lead" set:html={content.whyGo.replace(/\b(קניון של 150 מטר גובה|47 מטר מעל הנהר|אין רכבת)\b/g, '<strong>$1</strong>')} />
        <div class="img-bleed">
          <img src={content.heroImage} alt={attr.name} loading="lazy" />
        </div>
        {content.heroImageCaption && <p class="img-caption">{content.heroImageCaption}</p>}
        {content.whyGoSuffix && <p class="lead" style="margin-top:14px;margin-bottom:0" set:html={content.whyGoSuffix.replace(/\b(אין רכבת)\b/g, '<strong>$1</strong>')} />}
      </section>

      <!-- 02 · לדעת לפני -->
      <section class="sec" id="know">
        <div class="sec-head"><span class="sec-num">02</span><span class="sec-title">לדעת לפני</span></div>
        <div class="facts-grid">
          {content.facts.map(f => (
            <div class="fact">
              <span class="fact-icon">{f.icon}</span>
              <div class="fact-lbl">{f.label}</div>
              <div class="fact-val">{f.val}</div>
            </div>
          ))}
        </div>
        {content.alerts.length > 0 && (
          <div style="margin-top:12px">
            {content.alerts.map(a => (
              <div class="alert-box" style={`${alertStyles[a.type]};margin-bottom:8px`} set:html={a.text} />
            ))}
          </div>
        )}
      </section>

      <!-- 03 · החוויה -->
      <section class="sec" id="experience">
        <div class="sec-head"><span class="sec-num">03</span><span class="sec-title">מה קורה בסיור</span></div>
        {content.secondImage && (
          <>
            <div class="img-bleed">
              <img src={content.secondImage} alt={`${attr.name} — החוויה`} loading="lazy" />
            </div>
            <div style="margin-bottom:16px"></div>
          </>
        )}
        <div class="flow">
          {content.flowSteps.map((step, i) => {
            const isLast = i === content.flowSteps.length - 1;
            return (
              <div class={`flow-row${step.highlight ? ' hl' : ''}`}>
                <div class="flow-mid">
                  <div class="flow-dot"></div>
                  {!isLast && <div class="flow-line"></div>}
                </div>
                <div class="flow-content">
                  <div class="flow-title">{step.title}</div>
                  <div class="flow-note">{step.note}</div>
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <!-- 04 · מה לקחת -->
      <section class="sec" id="bring">
        <div class="sec-head"><span class="sec-num">04</span><span class="sec-title">מה לקחת</span></div>
        <div class="bring-hint">👆 הקש על פריט כדי לסמן שארזת — נשמר במכשיר</div>
        <div class="bring-grid" id="bring">
          {content.bringItems.map(item => (
            <div class={`bring-item${item.no ? ' no' : ''}`} data-key={item.no ? undefined : item.label}>
              <span class="bi">{item.icon}</span><span class="bi-label">{item.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- 04.5 · מסלול והתמצאות -->
      {rg && (
        <section class="sec" id="route">
          <div class="sec-head"><span class="sec-num">★</span><span class="sec-title">🥾 מסלול והתמצאות</span></div>
          <div class="facts-grid">
            {rg.facts.map(f => (
              <div class="fact">
                <span class="fact-icon">{f.icon}</span>
                <div class="fact-lbl">{f.label}</div>
                <div class="fact-val">{f.val}</div>
              </div>
            ))}
          </div>
          <div id="trailmap" style="height:260px;border-radius:8px;overflow:hidden;margin:14px 0;border:1px solid var(--border)"></div>
          {rg.schematic && <p class="img-caption" style="margin-top:-8px;text-align:right">⚠️ המסלול על המפה סכמטי — למסלול המדויק ראו את מפת הפארק הרשמית.</p>}
          <div class="flow" style="margin-top:8px">
            {rg.steps.map((step, i) => (
              <div class="flow-row">
                <div class="flow-mid">
                  <div class="flow-dot"></div>
                  {i !== rg.steps.length - 1 && <div class="flow-line"></div>}
                </div>
                <div class="flow-content">
                  <div class="flow-title">{step.title}</div>
                  <div class="flow-note">{step.note}</div>
                </div>
              </div>
            ))}
          </div>
          {rg.tip && <div class="alert-box" style={`${alertStyles['info']};margin-top:10px`} set:html={rg.tip} />}
          {rg.links && rg.links.length > 0 && (
            <>
              <div style="font-size:11px;color:var(--muted);margin:14px 0 6px">🧭 מפות והתמצאות:</div>
              <div class="btn-row" style="flex-wrap:wrap;gap:8px">
                {rg.links.map(l => (
                  <a class={`btn ${l.kind === 'map' ? 'btn-primary' : 'btn-ghost'}`} href={l.url} target="_blank" rel="noopener">
                    {l.kind === 'map' ? '🗺️ ' : l.kind === 'blog' ? '📖 ' : '🌐 '}{l.label}
                  </a>
                ))}
              </div>
            </>
          )}
        </section>
      )}

      <!-- 05 · מעשי -->
      <section class="sec" id="practical">
        <div class="sec-head"><span class="sec-num">05</span><span class="sec-title">מעשי</span></div>
        <div class="alert-box" style={`${alertStyles['ok']};margin-bottom:16px`}>
          <strong>📍 מיקום:</strong> {attr.mapUrl ? <a href={attr.mapUrl} target="_blank" rel="noopener" style="color:var(--green)">Google Maps</a> : 'ראה מפה'}
          {attr.siteUrl && <><br/><strong>🌐 אתר רשמי:</strong> <a href={attr.siteUrl} target="_blank" rel="noopener" style="color:var(--green)">{attr.siteUrl.replace('https://', '').split('/')[0]}</a></>}
        </div>
        {/* Map iframe per attraction */}
        {attr.googleMapsDir && (
          <div style="margin:12px 0 16px">
            <a
              href={attr.googleMapsDir}
              target="_blank"
              rel="noopener"
              style="display:flex;align-items:center;justify-content:center;gap:8px;padding:12px;background:var(--cream,#f5f0e8);border:1px solid rgba(0,0,0,.12);border-radius:10px;text-decoration:none;font-size:13px;font-weight:700;color:#1a1a1a"
            >
              🗺️ פתח מסלול ב-Google Maps
            </a>
          </div>
        )}
        <div class="btn-row">
          {attr.siteUrl && (
            <a class="btn btn-primary" href={attr.siteUrl} target="_blank" rel="noopener">🎫 אתר רשמי וכרטיסים</a>
          )}
          {attr.mapUrl && (
            <a class="btn btn-ghost" href={attr.mapUrl} target="_blank" rel="noopener">📍 מפה</a>
          )}
        </div>
      </section>
    </>
  ) : (
    /* Fallback for attractions without rich content */
    <>
      <section class="sec" id="info">
        <div class="sec-head"><span class="sec-num">01</span><span class="sec-title">על האטרקציה</span></div>
        <p class="lead">{attr.desc}</p>
        {attr.images?.[1] && (
          <div class="img-bleed">
            <img src={attr.images[1]} alt={attr.name} loading="lazy" />
          </div>
        )}
      </section>
      <section class="sec" id="practical">
        <div class="sec-head"><span class="sec-num">02</span><span class="sec-title">מעשי</span></div>
        <div class="btn-row">
          {attr.siteUrl && <a class="btn btn-primary" href={attr.siteUrl} target="_blank" rel="noopener">🔗 אתר רשמי</a>}
          {attr.mapUrl  && <a class="btn btn-ghost"   href={attr.mapUrl}  target="_blank" rel="noopener">📍 מפה</a>}
        </div>
      </section>
    </>
  )}

</div>

<script>
  const links = document.querySelectorAll('.sn');
  const ids = ['why','know','experience','bring','practical','info'];
  window.addEventListener('scroll', () => {
    const y = window.scrollY + 110;
    let cur = ids[0];
    ids.forEach(id => { const el = document.getElementById(id); if (el && el.offsetTop <= y) cur = id; });
    links.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + cur));
  }, { passive: true });
</script>

<script is:inline define:vars={{ slug }}>
  (function () {
    var key = 'pack:' + slug;
    var done = {};
    try { done = JSON.parse(localStorage.getItem(key) || '{}'); } catch (e) {}
    document.querySelectorAll('#bring .bring-item[data-key]').forEach(function (el) {
      var k = el.getAttribute('data-key');
      if (done[k]) el.classList.add('done');
      el.addEventListener('click', function () {
        el.classList.toggle('done');
        done[k] = el.classList.contains('done');
        try { localStorage.setItem(key, JSON.stringify(done)); } catch (e) {}
      });
    });
  })();
</script>

{rg && (
  <>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.js"></script>
    <script is:inline define:vars={{ rg }}>
      (function () {
        var el = document.getElementById('trailmap');
        if (!el || typeof L === 'undefined') return;
        var map = L.map('trailmap', { scrollWheelZoom: false });
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png', { subdomains: 'abcd', maxZoom: 19, attribution: '© OpenStreetMap, © CARTO' }).addTo(map);
        var colors = { start: '#1a73e8', via: '#1d9e75', end: '#c05a30' };
        var pts = [];
        rg.points.forEach(function (p, i) {
          var c = colors[p.type] || '#1d9e75';
          var label = p.type === 'start' ? '🅿' : (p.type === 'end' ? '🏁' : i);
          L.marker([p.lat, p.lng], { icon: L.divIcon({ className: '', iconSize: [26, 26], iconAnchor: [13, 13], popupAnchor: [0, -13], html: '<div style="width:26px;height:26px;border-radius:50%;background:' + c + ';border:2px solid #fff;box-shadow:0 1px 5px rgba(0,0,0,.5);color:#fff;font-weight:700;font-size:13px;display:flex;align-items:center;justify-content:center">' + label + '</div>' }) }).addTo(map).bindPopup(p.label);
          pts.push([p.lat, p.lng]);
        });
        if (pts.length > 1) L.polyline(pts, { color: '#c05a30', weight: 3, opacity: 0.6, dashArray: '6,8' }).addTo(map);
        if (pts.length === 1) map.setView(pts[0], rg.mapZoom || 14);
        else map.fitBounds(pts, { padding: [45, 45] });
        var me = null;
        map.on('locationfound', function (e) { if (me) map.removeLayer(me); me = L.circleMarker(e.latlng, { radius: 8, color: '#fff', weight: 3, fillColor: '#1a73e8', fillOpacity: 1 }).addTo(map).bindPopup('📍 אתה כאן'); });
        var B = L.Control.extend({ options: { position: 'topleft' }, onAdd: function () { var a = L.DomUtil.create('a', 'leaflet-bar'); a.href = '#'; a.title = 'המיקום שלי'; a.innerHTML = '📍'; a.style.cssText = 'width:34px;height:34px;line-height:34px;text-align:center;font-size:18px;background:#fff;display:block'; L.DomEvent.on(a, 'click', function (ev) { L.DomEvent.preventDefault(ev); map.locate({ setView: true, maxZoom: 15 }); }); return a; } });
        map.addControl(new B());
      })();
    </script>
  </>
)}

