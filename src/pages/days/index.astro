---
import Base from '../../layouts/Base.astro';
import { days } from '../../data/trip';

const base = import.meta.env.BASE_URL;

const dates: Record<number, string> = {
  1: 'רביעי 6.8',  2: 'חמישי 7.8',  3: 'שישי 8.8',
  4: 'שבת 9.8',    5: 'ראשון 10.8', 6: 'שני 11.8',
  7: 'שלישי 12.8', 8: 'רביעי 13.8', 9: 'חמישי 14.8',
  10: 'שישי 15.8', 11: 'שבת 16.8',  12: 'ראשון 17.8',
  13: 'שני 18.8',
};

const bases: Record<number, string> = {
  1: 'שקוצ\'יאן', 2: 'פליטביצה', 3: 'פליטביצה',
  4: 'Terme Čatež', 5: 'בלד', 6: 'בלד',
  7: 'בלד', 8: 'בלד', 9: 'בוץ\'',
  10: 'בוץ\'', 11: 'בוץ\'', 12: 'בוץ\'',
  13: 'ונציה',
};
---

<Base title="כל הימים · סלובניה">

<style>
  .days-hero {
    padding: 32px 20px 20px;
    text-align: center;
  }
  .days-hero h1 {
    font-size: 26px;
    font-weight: 900;
    color: var(--brown);
    letter-spacing: -.02em;
    margin-bottom: 4px;
  }
  .days-hero p {
    font-size: 14px;
    color: var(--muted);
  }

  .days-list {
    padding: 0 14px 60px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 640px;
    margin: 0 auto;
  }

  .day-card {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--warm);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    overflow: hidden;
    box-shadow: 0 1px 4px var(--shadow);
    transition: transform .15s, box-shadow .15s, border-color .15s;
  }
  .day-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px var(--shadow);
    border-color: var(--terra);
  }

  /* Number column */
  .day-num-col {
    width: 52px;
    min-height: 72px;
    background: var(--brown);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    gap: 2px;
  }
  .day-num-big {
    font-size: 20px;
    font-weight: 900;
    color: white;
    line-height: 1;
  }
  .day-num-date {
    font-size: 9px;
    color: rgba(255,255,255,0.65);
    letter-spacing: .04em;
    text-align: center;
    line-height: 1.3;
    padding: 0 4px;
  }

  /* Content */
  .day-content {
    flex: 1;
    padding: 12px 14px;
    min-width: 0;
  }
  .day-card-title {
    font-size: 14px;
    font-weight: 800;
    color: var(--brown);
    line-height: 1.3;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .day-card-sub {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .day-card-base {
    font-size: 11px;
    color: var(--terra);
    font-weight: 600;
    margin-top: 4px;
  }

  /* Badge + arrow */
  .day-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    padding: 12px 12px 12px 0;
    flex-shrink: 0;
  }
  .day-badge {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 99px;
    letter-spacing: .05em;
    white-space: nowrap;
  }
  .b-full      { background: #e8f4e8; color: #2a6e2a; }
  .b-highlight { background: #fff3cd; color: #8a6000; }
  .b-light     { background: #e8f0fe; color: #1a4db0; }
  .b-transit   { background: #f0f0f0; color: #666; }

  .day-arrow {
    font-size: 16px;
    color: var(--terra);
    opacity: .6;
  }

  /* Ticket alert */
  .ticket-alert {
    margin: 0 14px 14px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
</style>

<div class="days-hero">
  <h1>📅 כל הימים</h1>
  <p>13 ימים · סלובניה וקרואטיה · אוגוסט 2026</p>
</div>

<div class="wrap" style="padding-top:0">
  <div class="ticket-alert">
    <div class="alert alert-ok">✅ כרטיסים מוזמנים: שקוצ'יאן · פוסטויניה · פליטביצה · וינטגר · ראפטינג</div>
  </div>
</div>

<div class="days-list">
  {days.map(day => (
    <a class="day-card" href={`${base}/days/${day.num}/`}>
      <div class="day-num-col">
        <div class="day-num-big">{day.num}</div>
        <div class="day-num-date">{dates[day.num]?.split(' ').join('\n')}</div>
      </div>
      <div class="day-content">
        <div class="day-card-title">{day.title}</div>
        <div class="day-card-sub">{day.subtitle}</div>
        {bases[day.num] && (
          <div class="day-card-base">📍 {bases[day.num]}</div>
        )}
      </div>
      <div class="day-right">
        <span class={`day-badge b-${day.type}`}>{day.badge}</span>
        <span class="day-arrow">›</span>
      </div>
    </a>
  ))}
</div>

</Base>
