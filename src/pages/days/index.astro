---
import Base from '../../layouts/Base.astro';
import { days } from '../../data/trip';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const bases: Record<number, string> = {
  0: 'ונציה', 1: 'שקוצ\'יאן', 2: 'פליטביצה', 3: 'פליטביצה',
  4: 'Terme Čatež', 5: 'בלד', 6: 'בלד', 7: 'בלד', 8: 'בלד',
  9: 'בווץ\'', 10: 'בווץ\'', 11: 'בווץ\'', 12: 'בווץ\'', 13: 'ונציה',
};
---
<Base title="כל הימים · סלובניה">
<style>
  .days-hero { padding:32px 20px 20px; text-align:center; }
  .days-hero h1 { font-size:26px; font-weight:900; color:var(--brown); letter-spacing:-.02em; margin-bottom:4px; }
  .days-hero p { font-size:14px; color:var(--muted); }
  .days-list { padding:0 14px 60px; display:flex; flex-direction:column; gap:10px; max-width:640px; margin:0 auto; }
  .day-card {
    display:flex; align-items:center; gap:0;
    background:var(--warm); border:1px solid var(--border); border-radius:12px;
    text-decoration:none; overflow:hidden; box-shadow:0 1px 4px var(--shadow);
    transition:transform .15s, box-shadow .15s, border-color .15s;
  }
  .day-card:hover { transform:translateY(-1px); box-shadow:0 4px 14px var(--shadow); border-color:var(--terra); }
  .day-num-col {
    width:52px; min-height:72px; background:var(--brown);
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .day-num-col.zero { background:#888; }
  .day-num-big { font-size:22px; font-weight:900; color:white; line-height:1; }
  .day-content { flex:1; padding:12px 14px; min-width:0; }
  .day-card-title { font-size:14px; font-weight:800; color:var(--brown); line-height:1.3; margin-bottom:3px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .day-card-sub { font-size:12px; color:var(--muted); line-height:1.4; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .day-card-base { font-size:11px; color:var(--terra); font-weight:600; margin-top:4px; }
  .day-right { display:flex; flex-direction:column; align-items:flex-end; gap:6px; padding:12px 12px 12px 0; flex-shrink:0; }
  .day-badge { font-size:10px; font-weight:700; padding:2px 8px; border-radius:99px; letter-spacing:.05em; white-space:nowrap; }
  .b-full      { background:#e8f4e8; color:#2a6e2a; }
  .b-highlight { background:#fff3cd; color:#8a6000; }
  .b-light     { background:#e8f0fe; color:#1a4db0; }
  .b-transit   { background:#f0f0f0; color:#666; }
  .day-arrow { font-size:16px; color:var(--terra); opacity:.6; }
  .ticket-bar { margin:0 14px 14px; max-width:640px; margin-left:auto; margin-right:auto; }
  .group-label { font-size:11px; font-weight:700; color:var(--muted); letter-spacing:.08em; text-transform:uppercase; padding:14px 14px 6px; max-width:640px; margin:0 auto; }
</style>

<div class="days-hero">
  <h1>📅 כל הימים</h1>
  <p>סלובניה וקרואטיה · קיץ</p>
</div>

<div class="wrap" style="padding-top:0">
  <div class="ticket-bar">
    <div class="alert alert-ok">✅ כרטיסים מוזמנים: שקוצ'יאן · פוסטויניה · פליטביצה · וינטגר · ראפטינג</div>
  </div>
</div>

<div class="days-list">
  {days.map(day => (
    <a class="day-card" href={`${base}/days/${day.num}/`}>
      <div class={`day-num-col${day.num === 0 ? ' zero' : ''}`}>
        <div class="day-num-big">{day.num}</div>
      </div>
      <div class="day-content">
        <div class="day-card-title">{day.title}</div>
        <div class="day-card-sub">{day.subtitle}</div>
        {bases[day.num] && <div class="day-card-base">📍 {bases[day.num]}</div>}
      </div>
      <div class="day-right">
        <span class={`day-badge b-${day.type}`}>{day.badge}</span>
        <span class="day-arrow">→</span>
      </div>
    </a>
  ))}
</div>
</Base>
