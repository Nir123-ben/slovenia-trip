---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "מסלול סלובניה — מדריך טיול משפחתי" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="manifest" href={`${base}/manifest.webmanifest`}>
  <meta name="theme-color" content="#2d1f14">
  <link rel="icon" type="image/svg+xml" href={`${base}/icon.svg`}>
  <link rel="apple-touch-icon" href={`${base}/icon.svg`}>
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="סלובניה">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;600;700;800&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --brown:      #2d1f14;
      --brown-mid:  #4a2e1a;
      --cream:      #f5f0e8;
      --warm:       #faf7f2;
      --terra:      #c05a30;
      --terra-bg:   rgba(192,90,48,.1);
      --sage:       #5a8060;
      --sage-bg:    rgba(90,128,96,.12);
      --gold:       #c8920a;
      --gold-light: #f0c050;
      --blue:       #1e5080;
      --blue-bg:    rgba(30,80,128,.1);
      --text:       #1e140a;
      --muted:      #6b5a4a;
      --border:     #ddd0c0;
      --shadow:     rgba(45,31,20,.1);
      --r:          13px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
    body {
      font-family: 'Heebo', sans-serif;
      background: var(--cream);
      color: var(--text);
      direction: rtl;
      line-height: 1.7;
      min-height: 100vh;
    }
    a { color: var(--blue); }
    img { max-width: 100%; display: block; }

    /* ── NAV ── */
    .topnav {
      background: var(--brown);
      position: sticky; top: 0; z-index: 100;
      box-shadow: 0 2px 16px rgba(0,0,0,.35);
    }
    .nav-inner {
      max-width: 780px; margin: 0 auto; padding: 0 16px;
      display: flex; align-items: center;
      justify-content: space-between; height: 56px;
    }
    .nav-logo {
      font-family: 'Fraunces', serif;
      font-size: 18px; font-weight: 700;
      color: var(--gold-light); text-decoration: none;
    }
    .nav-links {
      display: flex; gap: 4px;
    }
    .nav-links a {
      color: rgba(255,255,255,.75); text-decoration: none;
      font-size: 13px; font-weight: 600;
      padding: 6px 12px; border-radius: 99px;
      transition: background .18s, color .18s;
    }
    .nav-links a:hover,
    .nav-links a.active { background: rgba(255,255,255,.12); color: var(--gold-light); }
    .ham {
      display: none; background: none; border: none;
      cursor: pointer; flex-direction: column; gap: 5px; padding: 8px;
    }
    .ham span { display: block; width: 22px; height: 2px; background: var(--cream); border-radius: 2px; }

    /* ── DRAWER ── */
    .drawer {
      position: fixed; top: 56px; right: 0;
      width: 260px; height: calc(100vh - 56px);
      background: var(--brown); z-index: 99;
      transform: translateX(110%); transition: transform .28s ease;
      overflow-y: auto; padding: 12px 0 40px;
    }
    .drawer.open { transform: translateX(0); }
    .overlay {
      position: fixed; inset: 56px 0 0 0;
      background: rgba(0,0,0,.5); z-index: 98; display: none;
    }
    .overlay.open { display: block; }
    .drawer-sec { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.4); padding: 16px 20px 6px; }
    .drawer a { display: block; color: rgba(255,255,255,.85); text-decoration: none; padding: 12px 20px; font-size: 15px; border-bottom: 1px solid rgba(255,255,255,.07); transition: background .18s; }
    .drawer a:hover { background: rgba(255,255,255,.08); }
    .drawer a.active { color: var(--gold-light); font-weight: 700; }

    /* ── WRAP ── */
    .wrap { max-width: 780px; margin: 0 auto; padding: 0 15px 60px; }

    /* ── HERO ── */
    .hero {
      background: var(--brown); padding: 52px 20px 60px;
      text-align: center; position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 20% 80%, rgba(200,146,10,.2) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 20%, rgba(90,128,96,.15) 0%, transparent 50%);
    }
    .hero-icon { font-size: 54px; margin-bottom: 16px; position: relative; }
    .hero h1 {
      font-family: 'Fraunces', serif; font-size: 34px; font-weight: 700;
      color: #fff; position: relative; margin-bottom: 8px; line-height: 1.15;
    }
    .hero-sub { font-size: 14px; color: var(--gold-light); position: relative; letter-spacing: .04em; }
    .hero-pill {
      display: inline-block; margin-top: 20px;
      border: 1px solid rgba(255,255,255,.2); border-radius: 99px;
      padding: 8px 22px; font-size: 13px; color: rgba(255,255,255,.7);
      position: relative;
    }

    /* page hero */
    .page-hero { background: var(--brown); padding: 32px 20px 40px; text-align: center; }
    .page-hero .ph-icon { font-size: 42px; margin-bottom: 10px; }
    .page-hero h1 { font-family: 'Fraunces', serif; font-size: 26px; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .page-hero p { font-size: 13px; color: var(--gold-light); }

    /* ── SECTION ── */
    .sec { padding-top: 32px; }
    .sec-title {
      font-family: 'Fraunces', serif;
      font-size: 19px; font-weight: 700; color: var(--brown);
      padding-bottom: 10px; margin-bottom: 16px;
      border-bottom: 2px solid var(--border);
    }

    /* ── CARDS ── */
    .card {
      background: var(--warm); border: 1px solid var(--border);
      border-radius: var(--r); padding: 18px; margin-bottom: 12px;
      box-shadow: 0 2px 10px var(--shadow);
    }

    /* ── ALERTS ── */
    .alert { padding: 11px 14px; border-radius: 10px; font-size: 13px; line-height: 1.7; margin-bottom: 10px; }
    .alert-ok   { background: #eaf4ec; border: 1px solid #a8c8ac; color: #1e5030; }
    .alert-warn { background: #fff7e0; border: 1px solid #e8c050; color: #6a4800; }
    .alert-info { background: #eaf0fb; border: 1px solid #a8c0e8; color: #1a3c70; }

    /* ── LINK BUTTONS ── */
    .btn-map, .btn-waze, .btn-site {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 12px; font-weight: 700; padding: 4px 11px;
      border-radius: 99px; text-decoration: none;
      margin-top: 6px; margin-left: 5px;
      transition: opacity .18s;
    }
    .btn-map  { background: #deeafb; color: #1a4a90; border: 1px solid #b0c8e8; }
    .btn-waze { background: #e8f4ff; color: #0060c0; border: 1px solid #90c0f0; }
    .btn-site { background: var(--cream); color: var(--muted); border: 1px solid var(--border); }
    .btn-map:hover, .btn-waze:hover, .btn-site:hover { opacity: .75; }

    /* ── DAY ACCORDION ── */
    .day-item {
      background: var(--warm); border: 1px solid var(--border);
      border-radius: var(--r); margin-bottom: 10px; overflow: hidden;
    }
    .day-hdr {
      display: flex; align-items: center; gap: 12px;
      padding: 16px; cursor: pointer; user-select: none;
      -webkit-tap-highlight-color: transparent;
    }
    .day-num { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 700; color: var(--terra); min-width: 36px; }
    .day-info { flex: 1; }
    .day-title { font-size: 15px; font-weight: 700; color: var(--brown); }
    .day-sub   { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .day-badge { font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 99px; white-space: nowrap; }
    .b-transit  { background: #e5eaf0; color: #3a5070; }
    .b-light    { background: var(--sage-bg); color: var(--sage); }
    .b-full     { background: #fef4e0; color: #8a5a10; }
    .b-star     { background: #fdecea; color: #9e2820; }
    .day-chev   { font-size: 13px; color: var(--muted); transition: transform .25s; flex-shrink: 0; }
    .day-item.open .day-chev { transform: rotate(180deg); }

    .day-body { display: none; padding: 0 16px 18px; border-top: 1px solid var(--border); }
    .day-item.open .day-body { display: block; }

    /* schedule */
    .sched { margin-top: 16px; }
    .srow { display: flex; gap: 12px; padding: 9px 0; border-bottom: 1px solid rgba(220,208,192,.5); align-items: flex-start; }
    .srow:last-child { border-bottom: none; }
    .stime { font-size: 13px; font-weight: 700; color: var(--terra); min-width: 46px; direction: ltr; text-align: left; font-variant-numeric: tabular-nums; padding-top: 2px; flex-shrink: 0; }
    .sdesc { font-size: 14px; line-height: 1.6; flex: 1; }
    .sdur  { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .slinks { display: flex; flex-wrap: wrap; gap: 0; }

    .day-note {
      margin-top: 14px; padding: 12px 14px;
      background: rgba(245,240,232,.9); border-radius: 10px;
      font-size: 13px; color: var(--muted); line-height: 1.7;
    }
    .bonus-box {
      margin-top: 10px; padding: 12px 14px;
      background: var(--blue-bg); border: 1px solid rgba(30,80,128,.2);
      border-radius: 10px; font-size: 13px; color: var(--blue); line-height: 1.7;
    }
    .bonus-lbl { font-weight: 700; font-size: 12px; margin-bottom: 3px; }
    .day-lodge { margin-top: 10px; font-size: 12px; color: var(--muted); padding: 8px 12px; background: var(--cream); border-radius: 8px; }

    /* ── ACCOMMODATION CARD ── */
    .lodge-card {
      background: var(--warm); border: 1px solid var(--border);
      border-radius: var(--r); padding: 16px; margin-bottom: 12px;
      box-shadow: 0 2px 10px var(--shadow);
    }
    .lodge-name { font-size: 16px; font-weight: 700; color: var(--brown); margin-bottom: 2px; }
    .lodge-sub  { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
    .lodge-row  { font-size: 13px; color: var(--muted); line-height: 2; }
    .lodge-links { margin-top: 10px; display: flex; flex-wrap: wrap; }

    /* ── MAP EMBED ── */
    .map-wrap { border-radius: var(--r); overflow: hidden; border: 1px solid var(--border); margin-bottom: 16px; box-shadow: 0 2px 10px var(--shadow); }
    .map-wrap iframe { display: block; width: 100%; height: 230px; border: none; }
    .map-note { font-size: 11px; color: var(--muted); margin-top: -10px; margin-bottom: 14px; padding: 6px 10px; background: var(--warm); border-radius: 0 0 var(--r) var(--r); border: 1px solid var(--border); border-top: none; }

    /* ── GRID ── */
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .stat-box { background: var(--warm); border: 1px solid var(--border); border-radius: 12px; padding: 14px; text-align: center; }
    .stat-val { font-family: 'Fraunces', serif; font-size: 24px; font-weight: 700; color: var(--brown); }
    .stat-lbl { font-size: 11px; color: var(--muted); margin-top: 2px; }

    /* ── TAGS ── */
    .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag { font-size: 12px; padding: 4px 10px; border-radius: 99px; background: var(--cream); color: var(--muted); border: 1px solid var(--border); }

    /* ── OPEN ALL ── */
    .open-all-btn {
      font-size: 13px; padding: 7px 18px; border-radius: 99px;
      border: 1px solid var(--border); background: var(--warm);
      cursor: pointer; margin-bottom: 14px; color: var(--brown);
      font-weight: 700; font-family: 'Heebo', sans-serif;
      transition: background .18s;
    }
    .open-all-btn:hover { background: var(--cream); }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .nav-links { display: none; }
      .ham { display: flex; }
      .hero h1 { font-size: 26px; }
      .grid2 { grid-template-columns: 1fr 1fr; }
    }
    @media (min-width: 601px) {
      .ham { display: none; }
      .drawer { display: none; }
    }
  </style>
</head>
<body>

<nav class="topnav">
  <div class="nav-inner">
    <a href={`${base}/`} class="nav-logo">🇸🇮 סלובניה</a>
    <div class="nav-links">
      <a href={`${base}/`}>ראשי</a>
      <a href={`${base}/days/`}>ימים 0–13</a>
      <a href={`${base}/map/`}>מפה</a>
      <a href={`${base}/tips/`}>טיפים</a>
      <a href={`${base}/info/`}>חשוב</a>
    </div>
    <button class="ham" id="ham" aria-label="תפריט"><span></span><span></span><span></span></button>
  </div>
</nav>
<div class="drawer" id="drawer">
  <div class="drawer-sec">ניווט</div>
  <a href={`${base}/`}>🏠 ראשי</a>
  <a href={`${base}/days/`}>📅 ימים 0–13</a>
  <a href={`${base}/map/`}>🗺️ מפה</a>
  <a href={`${base}/tips/`}>💡 טיפים</a>
  <a href={`${base}/info/`}>⚠️ חשוב</a>
</div>
<div class="overlay" id="overlay"></div>

<slot />

<footer style="text-align:center; padding:26px 16px 34px; margin-top:44px; border-top:1px solid var(--border); font-size:11px; line-height:1.9; color:var(--muted)">
  🇸🇮 מסלול סלובניה · מדריך משפחתי<br>
  תמונות באדיבות <a href="https://commons.wikimedia.org" target="_blank" rel="noopener" style="color:var(--muted)">Wikimedia Commons</a> (רישיון חופשי) · מפות © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener" style="color:var(--muted)">OpenStreetMap</a>, © CARTO
</footer>

<script>
  const ham = document.getElementById('ham');
  const drawer = document.getElementById('drawer');
  const overlay = document.getElementById('overlay');
  ham?.addEventListener('click', () => {
    drawer?.classList.toggle('open');
    overlay?.classList.toggle('open');
  });
  overlay?.addEventListener('click', () => {
    drawer?.classList.remove('open');
    overlay?.classList.remove('open');
  });
  // accordion
  document.querySelectorAll('.day-hdr').forEach(hdr => {
    hdr.addEventListener('click', () => hdr.closest('.day-item')?.classList.toggle('open'));
  });
  // open-all
  const oaBtn = document.getElementById('open-all');
  if (oaBtn) {
    let open = false;
    oaBtn.addEventListener('click', () => {
      open = !open;
      document.querySelectorAll('.day-item').forEach(d => d.classList.toggle('open', open));
      oaBtn.textContent = open ? 'סגור הכל' : 'פתח הכל';
    });
  }
</script>

<script is:inline define:vars={{ base }}>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function () {
      navigator.serviceWorker.register(base + '/sw.js').catch(function () {});
    });
  }
</script>
</body>
</html>
